# Maintainer: FxSound community
pkgname=fxsound
pkgver=1.2.8.0
pkgrel=1
pkgdesc="Real-time audio enhancer and equalizer (Linux/PipeWire port)"
arch=('x86_64' 'aarch64')
url="https://github.com/fxsound2/fxsound-app"
license=('AGPL3')
depends=('pipewire' 'libx11' 'libxext' 'libxinerama' 'libxrandr' 'libxcursor'
         'freetype2' 'fontconfig' 'mesa' 'alsa-lib' 'glib2' 'gtk-update-icon-cache')
makedepends=('cmake' 'ninja' 'git')
source=()
sha256sums=()

# Repo root — PKGBUILD lives in packaging/ inside the repo.
_repo="$startdir/.."

prepare() {
    git -C "$_repo" submodule update --init Resources
    # Shallow-clone JUCE 6.1.6 only if not already present.
    if [[ ! -d "$_repo/third_party/JUCE" ]]; then
        git clone --depth=1 --branch 6.1.6 \
            https://github.com/juce-framework/JUCE \
            "$_repo/third_party/JUCE"
    fi
}

build() {
    cmake -S "$_repo" -B "$srcdir/build" -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build "$srcdir/build" --parallel
}

package() {
    DESTDIR="$pkgdir" cmake --install "$srcdir/build"
}

post_install() {
    gtk-update-icon-cache -qtf usr/share/icons/hicolor
    update-desktop-database -q
}

post_upgrade() {
    post_install
}
